# Django
SECRET_KEY=django-insecure-safeweb-ai-dev-key-change-in-production-2026
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=sqlite:///db.sqlite3

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI API
OPENAI_API_KEY=

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# File scanning
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=exe,dll,pdf,doc,docx,xls,xlsx,zip,rar,py,js,php

# Scan limits
MAX_CONCURRENT_SCANS=10
SCAN_TIMEOUT_SECONDS=3600
MAX_CRAWL_PAGES=200
